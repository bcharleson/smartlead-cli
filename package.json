{
  "name": "@bcharleson/smartlead-cli",
  "version": "0.1.5",
  "description": "CLI and MCP server for the Smartlead.ai API — campaigns, leads, email accounts, sequences, analytics, webhooks, and client management",
  "type": "module",
  "bin": {
    "smartlead": "dist/index.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "smartlead",
    "email-outreach",
    "cold-email",
    "sales-automation",
    "campaigns",
    "leads",
    "cli",
    "mcp",
    "ai-agent",
    "automation"
  ],
  "author": "Brandon Charleson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bcharleson/smartlead-cli.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
